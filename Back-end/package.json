{
  "name": "assofig-backend",
  "version": "1.0.0",
  "private": true,
  "description": "API REST da aplicação ASSOFIG",
  "main": "dist/src/app.js",
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/local.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@vercel/functions": "^3.7.5",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "8.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.16.3",
    "resend": "^6.17.2",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.1.3",
    "tsx": "^4.20.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "type": "module"
}
